# docker/.env.example
#
# Optional Docker Compose env file (used for variable substitution in docker/docker-compose.yml).
# Copy to docker/.env and adjust paths if you want bind mounts instead of named volumes:
#
#   cp docker/.env.example docker/.env
#   docker compose --env-file docker/.env -f docker/docker-compose.yml --profile frontend up --build
#
# If you skip this file, docker/docker-compose.yml will fall back to named volumes under Docker.

PROJECT_SLUG=charaforge-t2i-lab

# Bind-mount your existing AI warehouse roots (host paths). If unset, named volumes are used.
AI_MODELS_ROOT_HOST=/mnt/c/ai_models
AI_CACHE_ROOT_HOST=/mnt/c/ai_cache
AI_DATASETS_ROOT_HOST=/mnt/data/datasets
AI_TRAINING_ROOT_HOST=/mnt/data/training

# Frontend -> API origin (used by api service CORS)
API_CORS_ORIGINS=http://localhost:3000

# Optional: choose how /api/v1/t2i/submit dispatches jobs (redis|celery).
# - redis: start `t2i_worker` (default)
# - celery: enable the `celery` profile to start `t2i_celery_worker`
API_T2I_DISPATCH_MODE=redis
