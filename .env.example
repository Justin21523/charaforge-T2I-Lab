# .env.example - Environment variables template
# CharaForge T2I Lab - Environment Configuration

# === AI_WAREHOUSE 3.0 (Required) ===
# See: ~/Desktop/data_model_structure.md
PROJECT_SLUG=charaforge-t2i-lab

# Models (2TB fast SSD)
AI_MODELS_ROOT=/mnt/c/ai_models

# Caches (2TB fast SSD) - NEVER under $HOME/.cache
AI_CACHE_ROOT=/mnt/c/ai_cache
XDG_CACHE_HOME=/mnt/c/ai_cache
HF_HOME=/mnt/c/ai_cache/huggingface
TRANSFORMERS_CACHE=/mnt/c/ai_cache/huggingface
TORCH_HOME=/mnt/c/ai_cache/torch

# Datasets + training outputs (4TB large SSD)
AI_DATASETS_ROOT=/mnt/data/datasets
AI_TRAINING_ROOT=/mnt/data/training

# === Compute ===
CUDA_VISIBLE_DEVICES=0

# === API Settings ===
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
# WebSocket auth: allow legacy query params (?api_key=... / ?access_token=...). Recommended false for production.
API_WS_ALLOW_QUERY_AUTH=true
# WebSocket ticket auth (recommended): short-lived, single-use signed ticket issued via `POST /api/v1/auth/ws_ticket`.
# Set to 0 to disable tickets and fall back to access_token/api_key subprotocol auth.
API_WS_TICKET_TTL_SECONDS=30
# When true, store used ticket IDs in Redis to detect replay (recommended).
API_WS_TICKET_REPLAY_PROTECTION=true
# Global rate limit (requests/minute, 0 disables)
API_RATE_LIMIT=100
# Bucket rate limits for auth endpoints (requests/minute, 0 disables)
API_AUTH_TOKEN_RATE_LIMIT=10
API_AUTH_REFRESH_RATE_LIMIT=30
# Stricter bucket for /api/v1/models/scan (requests/minute, 0 disables)
API_SCAN_RATE_LIMIT=5
# Async /api/v1/models/scan/* jobs (Redis recommended)
API_MODELS_SCAN_WORKER_ENABLED=true
# TTL for terminal scan jobs in Redis (seconds, 0 disables)
API_MODELS_SCAN_JOB_TTL_SECONDS=3600
# Bucket rate limits (requests/minute, 0 disables)
API_UPLOAD_RATE_LIMIT=30
API_DATASETS_RATE_LIMIT=60

# Async T2I job queue (Redis recommended)
API_T2I_WORKER_ENABLED=true
# Job dispatch mode:
# - redis: uses Redis list queue + worker thread/process (default)
# - celery: enqueues Celery tasks per job (recommended with a dedicated `t2i` worker)
API_T2I_DISPATCH_MODE=redis
# TTL for terminal jobs in Redis (seconds, 0 disables)
API_T2I_JOB_TTL_SECONDS=86400
# Requeue/mark-failed if a worker stops updating a job for this long (seconds)
API_T2I_JOB_STALE_SECONDS=600
# Max requeue attempts before failing a stale job
API_T2I_JOB_MAX_ATTEMPTS=2
# Optional: delete output folders older than this (seconds, 0 disables)
API_T2I_OUTPUT_TTL_SECONDS=0
# Per-owner limits
API_T2I_MAX_CONCURRENT=1
API_T2I_MAX_QUEUE=8
# Global limits (across all owners/workers, 0 disables)
API_T2I_MAX_GLOBAL_CONCURRENT=1
API_T2I_MAX_GLOBAL_QUEUE=0
# Optional cost-based rate limit for T2I/ControlNet (cost units/minute, 0 disables)
API_T2I_COST_RATE_LIMIT=0

# === Redis/Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === HuggingFace (Optional) ===
HF_TOKEN=your_huggingface_token_here

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=/mnt/data/training/logs/charaforge-t2i-lab/api.log
LOG_JSON=false

# === Features ===
ENABLE_SAFETY_CHECKS=true
ENABLE_WATERMARKS=true
ENABLE_CONTROLNET=true

# === Development ===
DEBUG=false
RELOAD=false

# === Optional: Database ===
DATABASE_URL=postgresql://user:pass@localhost:5432/charaforge

# === Optional: Authentication ===
# Used for optional signing (e.g. JWT/signed URLs) when enabled in the codebase.
JWT_SECRET=your-secret-key-here
# JWT access/refresh lifetimes (seconds).
API_JWT_ACCESS_TTL_SECONDS=900
API_JWT_REFRESH_TTL_SECONDS=2592000
# Refresh replay detection window (seconds). Old rotated refresh tokens are kept briefly to detect replay.
API_JWT_REFRESH_REPLAY_WINDOW_SECONDS=86400
# Refresh cookie/CSRF settings (cookie mode is used by /api/v1/auth/refresh and /api/v1/auth/logout).
API_JWT_REFRESH_COOKIE_NAME=cfr_refresh
API_JWT_CSRF_COOKIE_NAME=cfr_csrf
# Cookie Path/Domain (usually keep Path to /api/v1/auth and Domain unset for local dev).
API_JWT_COOKIE_PATH=/api/v1/auth
# API_JWT_COOKIE_DOMAIN=example.com
# Cookie SameSite: lax|strict|none (use "none" only for cross-site setups; requires Secure=true).
API_JWT_COOKIE_SAMESITE=lax
# Secure cookies (recommend true in production behind HTTPS).
API_JWT_COOKIE_SECURE=false
# Prefer role-based API keys (comma-separated):
# - API_ADMIN_KEYS: full access (includes /api/v1/models/scan)
# - API_KEYS: standard access
API_ADMIN_KEYS=your-admin-key-here
API_KEYS=your-user-key-here
# Legacy single-key mode (treated as an admin key)
API_KEY=your-legacy-admin-key-here
API_KEY_HEADER=X-API-Key
# Managed keys created via /api/v1/auth/* are stored hashed under $AI_CACHE_ROOT/auth/api_keys.json

# === Optional: Monitoring ===
SENTRY_DSN=your-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.0
PROMETHEUS_ENABLED=false
